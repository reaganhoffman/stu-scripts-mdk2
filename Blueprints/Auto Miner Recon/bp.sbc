STULog(string sender,string message,string type,Dictionary&lt;string,string&gt;metadata=null){Sender=sender;Message=message;Type=
type;Metadata=metadata;}public static STULog Deserialize(string s){string[]components=s.Split(new string[]{
COMPONENT_DELIMITER},StringSplitOptions.None);string logType=components[2];switch(components.Length){case 3:return new STULog(components[0]
,components[1],logType);case 4:return new STULog(components[0],components[1],logType,ParseMetadata(components[3]));
default:throw new ArgumentException($"Malformed log string; invalid number of components: {components.Length}.");}}private
static Dictionary&lt;string,string&gt;ParseMetadata(string metadataString){Dictionary&lt;string,string&gt;metadata=new Dictionary&lt;string,
string&gt;();string[]metadataKeyValuePairs=metadataString.Split(new string[]{METADATA_DELIMITER},StringSplitOptions.None);foreach
(string pair in metadataKeyValuePairs){string[]keyValue=pair.Split('=');string key=keyValue[0].Trim();string value=
keyValue[1].Trim();metadata.Add(key,value);}return metadata;}public static Color GetColor(string type){switch(type){case
STULogType.OK:return Color.Green;case STULogType.ERROR:return Color.Red;case STULogType.WARNING:return Color.Yellow;case
