public bool FinishedExporting{get{return finishedExporting;}private set{finishedExporting=value;}}public STUImage(List&lt;List&lt;
Pixel&gt;&gt;image){pixelArray=image;}public STUImage(){pixelArray=new List&lt;List&lt;Pixel&gt;&gt;(){};}public void ExportOverTime(
IMyTerminalBlock outputBlock){if(ExportStateMachine!=null){bool hasMoreSteps=ExportStateMachine.MoveNext();if(!hasMoreSteps){
