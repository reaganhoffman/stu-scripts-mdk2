))/2f)-padding,0);break;case SpriteType.TEXTURE:childSprite.Position-=new Vector2(((parentSprite.Size.Value.X-childSprite
.Size.Value.X)/2f)-padding,0);break;}}public void AlignRightWithinParent(MySprite parentSprite,ref MySprite childSprite,
float padding=0){if(NeedToCenterSprite){AlignCenterWithinParent(parentSprite,ref childSprite);}switch(childSprite.Type){case
SpriteType.TEXT:childSprite.Position+=new Vector2(((parentSprite.Size.Value.X-GetTextSpriteWidth(childSprite))/2f)-padding,0);
break;case SpriteType.TEXTURE:childSprite.Position+=new Vector2(((parentSprite.Size.Value.X-childSprite.Size.Value.X)/2f)-
padding,0);break;}}public void AlignTopWithinParent(MySprite parentSprite,ref MySprite childSprite,float padding=0){if(
NeedToCenterSprite){AlignCenterWithinParent(parentSprite,ref childSprite);}switch(childSprite.Type){case SpriteType.TEXT:childSprite.
Position-=new Vector2(0,((parentSprite.Size.Value.Y-GetTextSpriteHeight(childSprite))/2f)-padding);break;case SpriteType.TEXTURE
:childSprite.Position-=new Vector2(0,((parentSprite.Size.Value.Y-childSprite.Size.Value.Y)/2f)-padding);break;}}public
void AlignBottomWithinParent(MySprite parentSprite,ref MySprite childSprite,float padding=0){if(NeedToCenterSprite){
