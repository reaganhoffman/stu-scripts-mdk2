&gt;Metadata{get{return metadata;}set{metadata=value;}}}class STUMasterLogBroadcaster{public string Channel{get;set;}public
IMyIntergridCommunicationSystem Broadcaster{get;set;}public TransmissionDistance Distance{get;set;}public STUMasterLogBroadcaster(string channel,
IMyIntergridCommunicationSystem IGC,TransmissionDistance distance){Channel=channel;Broadcaster=IGC;Distance=distance;}public void Log(STULog log,string
