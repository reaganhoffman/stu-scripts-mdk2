parentSprite.Size.Value.Y-GetTextSpriteHeight(childSprite))/2f)-padding);break;case SpriteType.TEXTURE:childSprite.Position+=new
Vector2(0,((parentSprite.Size.Value.Y-childSprite.Size.Value.Y)/2f)-padding);break;}}public void AlignTopLeftWithinParent(
