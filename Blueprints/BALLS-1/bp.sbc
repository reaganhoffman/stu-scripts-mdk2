IsSameConstructAs(PB));return intermediateList.ToArray();}public static T[]LoadAllBlocksOfTypeWithSubtypeId&lt;T&gt;(string subtype)where T:
class,IMyTerminalBlock{var intermediateList=new List&lt;T&gt;();Grid.GetBlocksOfType(intermediateList,block=&gt;block.
IsSameConstructAs(PB)&amp;&amp;block.BlockDefinition.SubtypeId.Contains(subtype));return intermediateList.ToArray();}public static T
