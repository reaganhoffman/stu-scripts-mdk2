                string accelerationString = $"Acceleration:\n   A_x = {AccelerationComponents.X.ToString("F2")}\n   A_y = {AccelerationComponents.Y.ToString("F2")}\n   A_z = {AccelerationComponents.Z.ToString("F2")}\n";

