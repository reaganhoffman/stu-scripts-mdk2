                     new ControlAction { Direction = Direction.Forward, Magnitude = 0 },
                     new ControlAction { Direction = Direction.Right, Magnitude = 0 }
                }
            },

            new Maneuver {
                Actions = new List&lt;ControlAction&gt; {
