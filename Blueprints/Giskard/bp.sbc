            // now for right and up

            new Maneuver {
                Actions = new List&lt;ControlAction&gt; {
                     new ControlAction { Direction = Direction.Right, Magnitude = 1 },
                     new ControlAction { Direction = Direction.Up, Magnitude = 5 },
