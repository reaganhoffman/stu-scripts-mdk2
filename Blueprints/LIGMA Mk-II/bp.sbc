IMyThrust[downCount];forwardCount=0;reverseCount=0;leftCount=0;rightCount=0;upCount=0;downCount=0;foreach(IMyThrust thruster in
allThrusters){Base6Directions.Direction thrusterDirection=RemoteControl.Orientation.TransformDirectionInverse(thruster.Orientation.
