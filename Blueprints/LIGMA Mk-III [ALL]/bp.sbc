return Camera.Raycast(RaycastDistance,RaycastPitch,RaycastYaw);}public void ToggleRaycast(){Camera.EnableRaycast=!Camera.
EnableRaycast;}public string GetHitInfoString(MyDetectedEntityInfo hit){double distance=Vector3D.Distance((Vector3D)hit.HitPosition,
