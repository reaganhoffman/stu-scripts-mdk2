GetSeaLevelAltitude();if(altitude&gt;TargetSeaLevelAltitude){CreateInfoFlightLog(
$"Descending to target sea level altitude: {TargetSeaLevelAltitude}");CurrentState=AltitudeState.Descending;}else if(altitude&lt;TargetSeaLevelAltitude){CreateInfoFlightLog(
$"Ascending to target sea level altitude: {TargetSeaLevelAltitude}");CurrentState=AltitudeState.Ascending;}return false;}public bool SetSurfaceVa(double desiredVelocity,double
