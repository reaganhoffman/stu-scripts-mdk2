VelocityController{private const double VELOCITY_ERROR_TOLERANCE=0.02;private const double GRAVITY_ERROR_TOLERANCE=0.02;private bool
ALREADY_COUNTERING_GRAVITY=false;private IMyThrust[]PosDirThrusters;private IMyThrust[]NegDirThrusters;public VelocityController(IMyThrust[]
posDirThrusters,IMyThrust[]negDirThrusters){PosDirThrusters=posDirThrusters;NegDirThrusters=negDirThrusters;}public bool SetVelocity(
double currentVelocity,double desiredVelocity,double gravityVectorComponent){double remainingVelocityToGain=desiredVelocity-
