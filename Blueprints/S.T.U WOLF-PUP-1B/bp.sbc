AltitudeState.Descending:if(SetSurfaceVa(-5,SurfaceAltitudeVelocity)){CurrentState=AltitudeState.Idle;}break;}return false;}public
bool MaintainSeaLevelAltitude(){switch(CurrentState){case AltitudeState.Idle:return IdleSeaLevelAltitude();case
