CurrentState=AltitudeState.Idle;STUVelocityController VelocityController{get;set;}STUFlightController FlightController{get;set;}
IMyRemoteControl RemoteControl{get;set;}public double TargetSeaLevelAltitude{get;set;}public double CurrentSeaLevelAltitude{get;set;}
